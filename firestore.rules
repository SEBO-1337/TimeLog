rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasUserDoc() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userRole() {
      return userDoc().data.role;
    }

    function isAdmin() {
      return hasUserDoc() && userRole() == 'ADMIN';
    }

    function isCustomer() {
      return hasUserDoc() && userRole() == 'CUSTOMER';
    }

    function isTechnician() {
      return hasUserDoc() && userRole() == 'TECHNICIAN';
    }

    function hasProjectAccess(projectId) {
      return isCustomer()
        && (
          projectId in userDoc().data.allowedProjectIds
          || (projectId + '') in userDoc().data.allowedProjectIds
        );
    }

    function isProjectCreator(createdBy) {
      return isTechnician() && createdBy == request.auth.uid;
    }

    function projectDocById(projectCloudId) {
      return get(/databases/$(database)/documents/shared/default/projects/$(projectCloudId + ''));
    }

    function technicianOwnProject(projectCloudId) {
      return isTechnician()
        && projectDocById(projectCloudId).exists()
        && projectDocById(projectCloudId).data.createdBy == request.auth.uid;
    }

    // Nutzerprofile und Rollen

    match /users/{userId} {
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.role == 'NEW'
        && request.resource.data.allowedProjectIds is list;

      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Rollen/Freigaben dürfen nur Admins setzen.
      allow update, delete: if isAdmin();
    }

    // Freigegebene Projektdaten
    match /shared/default/projects/{projectDocId} {
      allow read: if isAdmin()
        || hasProjectAccess(projectDocId)
        || isProjectCreator(resource.data.createdBy);

      // Admin darf alles.
      allow create: if isAdmin()
        || (
          isTechnician()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.cloudId == projectDocId
        );

      // Technician darf nur eigene Projekte aktualisieren.
      allow update: if isAdmin()
        || (
          isTechnician()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.cloudId == resource.data.cloudId
        );

      // Technician darf nur eigene Projekte löschen.
      allow delete: if isAdmin()
        || (isTechnician() && resource.data.createdBy == request.auth.uid);
    }

    match /shared/default/workLogs/{workLogId} {
      allow read: if isAdmin()
        || hasProjectAccess(resource.data.projectCloudId)
        || (isTechnician() && resource.data.createdBy == request.auth.uid);

      // WorkLog erstellen: Admin oder der eingeloggte Technician (createdBy == uid).
      allow create: if isAdmin()
        || (
          isTechnician()
          && request.resource.data.createdBy == request.auth.uid
          && technicianOwnProject(request.resource.data.projectCloudId)
        );

      // WorkLog ändern: Technician nur an eigenen WorkLogs.
      allow update: if isAdmin()
        || (
          isTechnician()
          && resource.data.createdBy == request.auth.uid
          && request.resource.data.createdBy == request.auth.uid
          && technicianOwnProject(resource.data.projectCloudId)
          && technicianOwnProject(request.resource.data.projectCloudId)
        );

      // WorkLog löschen: Technician nur eigene.
      allow delete: if isAdmin()
        || (
          isTechnician()
          && resource.data.createdBy == request.auth.uid
          && technicianOwnProject(resource.data.projectCloudId)
        );
    }

    match /shared/default/meta/{metaDoc} {
      // CUSTOMER und TECHNICIAN darf meta-Dokumente lesen; Filterung nach Projekt erfolgt im App-Code.
      allow read: if isAdmin() || isCustomer() || isTechnician();

      // activeTimer darf auch von Technician geschrieben werden, aber nur fuer eigene Projekte.
      allow write: if isAdmin()
        || (
          isTechnician()
          && metaDoc == 'activeTimer'
          && request.resource != null
          && technicianOwnProject(request.resource.data.projectCloudId)
        )
        || (
          isTechnician()
          && metaDoc == 'activeTimer'
          && request.resource == null
        );
    }

    // Standard: alles andere gesperrt.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

